# ============================================================
# RACEBOT — Variabili d'ambiente
# Copia questo file come ".env" e compila i valori reali
# NON committare mai il file .env su Git
# ============================================================

# --- Claude API (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXXXXXX

# --- Database (quando servirà — Sprint 2) ---
# Crea un progetto Supabase SEPARATO da quello di FIAP
DATABASE_URL=postgresql://user:password@host:5432/racebot_db

# --- App settings ---
APP_ENV=development
APP_PORT=8000
SECRET_KEY=cambia-questa-stringa-con-qualcosa-di-random

# --- Email transazionali (Sprint 3) ---
RESEND_API_KEY=re_XXXXXXXXXXXXXXXX
EMAIL_FROM=noreply@racebot.it

# --- Storage documenti (locale per ora) ---
UPLOAD_DIR=./uploads
CHROMA_DIR=./chroma_db
